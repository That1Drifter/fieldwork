# Copy to .env and fill in your values.

# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# HTTP Basic Auth. Leave FIELDWORK_AUTH_PASS empty to disable auth entirely
# (fine for local dev). Set it to activate auth on every route except
# /api/health. Default username is "fieldwork" if FIELDWORK_AUTH_USER is unset.
FIELDWORK_AUTH_USER=fieldwork
FIELDWORK_AUTH_PASS=

# Optional: override the default model used for environment and debrief calls.
# FIELDWORK_MODEL_ENV=claude-haiku-4-5
# FIELDWORK_MODEL_STAKEHOLDER=claude-sonnet-4-6
# FIELDWORK_MODEL_DEBRIEF=claude-sonnet-4-6
