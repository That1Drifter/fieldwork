{
  "name": "fieldwork",
  "version": "0.0.0",
  "private": true,
  "description": "Practice forward-deployed engineering against simulated customer environments.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "validate-scenarios": "turbo run validate --filter=@fieldwork/scenarios",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0"
  }
}
