{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fieldwork.dev/schema/scenario.v1.json",
  "title": "Fieldwork Scenario Manifest",
  "description": "Declarative definition of a fieldwork training scenario.",
  "type": "object",
  "required": ["id", "version", "tier", "title", "world", "objectives"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Unique, URL-safe scenario identifier."
    },
    "version": { "type": "integer", "minimum": 1 },
    "tier": { "type": "integer", "minimum": 1, "maximum": 3 },
    "title": { "type": "string", "minLength": 1 },
    "tagline": { "type": "string" },
    "estimated_duration_minutes": { "type": "integer", "minimum": 1 },
    "estimated_cost_usd": { "type": "number", "minimum": 0 },
    "turn_budget": {
      "type": "integer",
      "minimum": 1,
      "description": "Optional hard cap on turns. When reached, the trainee must run debrief."
    },
    "world": {
      "type": "object",
      "required": ["company"],
      "additionalProperties": false,
      "properties": {
        "company": {
          "type": "object",
          "required": ["name", "industry"],
          "additionalProperties": true,
          "properties": {
            "name": { "type": "string" },
            "industry": { "type": "string" },
            "headcount": { "type": "integer", "minimum": 1 },
            "maturity": { "type": "string" }
          }
        },
        "tech_stack": { "type": "array", "items": { "type": "string" } },
        "stakeholders": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "role"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "role": { "type": "string" },
              "traits": {
                "type": "object",
                "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
              },
              "goals": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "data_generators": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": true,
        "properties": {
          "type": { "type": "string" },
          "count": { "type": "integer", "minimum": 0 },
          "seed": { "type": "integer" },
          "distribution": {
            "type": "object",
            "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "noise": {
            "type": "object",
            "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "desc"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "desc": { "type": "string" },
          "required": { "type": "boolean", "default": false },
          "discoverable": {
            "type": "boolean",
            "default": false,
            "description": "When true, this objective is hidden from the trainee until surfaced through discovery (stakeholder mention or a question that touches on it)."
          }
        }
      }
    },
    "surprises": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "trigger", "detail"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "trigger": {
            "type": "object",
            "required": ["type"],
            "additionalProperties": true,
            "properties": {
              "type": {
                "type": "string",
                "enum": ["turn_count", "objective_state", "action_pattern", "random"]
              }
            }
          },
          "detail": { "type": "string" },
          "visible": { "type": "boolean" },
          "channel": { "type": "string" },
          "from": { "type": "string" }
        }
      }
    },
    "rubric": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "debrief": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model": { "type": "string" },
        "batch": { "type": "boolean" },
        "focus": { "type": "string" }
      }
    }
  }
}
